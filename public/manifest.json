{
  "manifest_version": 3,
  "name": "PrayerTab",
  "short_name": "PrayerTab",
  "description": "A spiritual new-tab experience for Muslims with prayer times, Quran reflection, and intentional daily focus.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "geolocation"
  ],
  "host_permissions": [
    "https://images.unsplash.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://api.open-meteo.com/*",
    "https://loremflickr.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}